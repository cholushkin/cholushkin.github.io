        ---
        layout: default
        title: Home
        ---
        <h1>📰 Blog</h1>
        <h2>🆕 Latest Posts</h2>
        <ul>
        {% for post in site.posts limit:5 %}
          <li>
            <a href="{{ post.url }}"><strong>{{ post.title }}</strong></a><br>
            <small>{{ post.date | date: "%Y-%m-%d" }}</small><br>
            {% for category in post.categories %}
              <small><a href="/{{ category }}/">#{{ category }}</a></small>
            {% endfor %}
          </li>
        {% endfor %}
        </ul>
        <hr>
        <h2>💭 Thoughts</h2>
        <ul>
        {% for post in site.categories.thoughts limit:3 %}
          <li>
            <a href="{{ post.url }}"><strong>{{ post.title }}</strong></a><br>
            {% for category in post.categories %}
              <small><a href="/{{ category }}/">#{{ category }}</a></small>
            {% endfor %}
          </li>
        {% endfor %}
        </ul>
        <p><a href="/thoughts/">→ View all Thoughts</a></p>
        <hr>
        <h2>🚀 Projects</h2>
        <ul>
        {% for post in site.categories.projects limit:3 %}
          <li>
            <a href="{{ post.url }}"><strong>{{ post.title }}</strong></a><br>
            {% for category in post.categories %}
              <small><a href="/{{ category }}/">#{{ category }}</a></small>
            {% endfor %}
          </li>
        {% endfor %}
        </ul>
        <p><a href="/projects/">→ View all Projects</a></p>
